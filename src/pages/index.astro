---
import { existsSync } from "node:fs";
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero.tsx";
import Countdown from "@/components/Countdown.tsx";

const year = new Date().getFullYear();

// Build a product's view list (front, back, side) from whichever image files
// actually exist yet — so the gallery never points at a not-yet-generated shot.
const viewsOf = (front: string) =>
  [
    front,
    front.replace(".webp", "-back.webp"),
    front.replace(".webp", "-side.webp"),
  ].filter((p) => existsSync(`./public${p}`));

// 🔧 EDIT ME: the real drop date/time (Pacific). Change this one line when you
// know your launch day — the countdown updates automatically.
const DROP_DATE = "2026-08-08T10:00:00-07:00";

// 🔧 EDIT ME: names are placeholders. Each product has a hidden "secret"
// sentence per colorway (revealed in the gallery popup). `tagName` swaps by
// colorway too (Flame ↔ Frost).
const products = [
  {
    name: "Flame Sneakers",
    tag: "Footwear",
    img: "/img/products/shoes.webp",
    sayingFire: "Where greatness starts.",
    sayingIce: "Where the cold begins.",
  },
  {
    name: "Flame Hoodie",
    tag: "Apparel",
    img: "/img/products/hoodie.webp",
    sayingFire: "This is not a hoodie. This is armor.",
    sayingIce: "Cold by choice.",
  },
  {
    name: "BB Ringer Tee",
    tag: "Apparel",
    img: "/img/products/tee.webp",
    sayingFire: "Certified bucket-getter.",
    sayingIce: "Cold-blooded scorer.",
  },
  {
    name: "Flame Shorts",
    tag: "Apparel",
    img: "/img/products/shorts.webp",
    sayingFire: "Legs of a legend.",
    sayingIce: "Freeze the competition.",
  },
  {
    name: "Flame Sweatpants",
    tag: "Apparel",
    img: "/img/products/sweatpants.webp",
    sayingFire: "Comfort is earned.",
    sayingIce: "Zero degrees. Zero fear.",
  },
  {
    name: "BB Bucket Hat",
    tag: "Headwear",
    img: "/img/products/hat.webp",
    sayingFire: "Crown of the G.O.A.T.",
    sayingIce: "Cold-minded.",
  },
  {
    name: "Flame Socks",
    tag: "Apparel",
    img: "/img/products/socks.webp",
    sayingFire: "Grounded greatness.",
    sayingIce: "Frozen footwork.",
  },
  {
    name: "BB Bracelets",
    tag: "Accessories",
    img: "/img/products/bracelets.webp",
    sayingFire: "Greatness is a habit.",
    sayingIce: "Iced out.",
  },
  {
    name: "Flame Boxers",
    tag: "Apparel",
    img: "/img/products/underwear.webp",
    sayingFire: "The foundation.",
    sayingIce: "Cold to the core.",
  },
];
---

<Layout title="B-BUCKETS — Buckets Incoming">
  {/* ---- Header ---- */}
  <header
    class="fixed inset-x-0 top-0 z-40 flex items-center justify-between bg-gradient-to-b from-background/90 to-transparent px-6 py-4 backdrop-blur-sm sm:px-10"
  >
    <a href="#top" class="flex items-center gap-3">
      <img
        src="/img/brand/logo-transparent.png"
        alt="B-BUCKETS logo"
        class="h-8 w-auto invert"
        width="48"
        height="32"
      />
    </a>
    <nav class="flex items-center gap-4 text-xs font-semibold tracking-[0.2em] uppercase sm:gap-6">
      <a href="#gear" class="hidden text-muted-foreground transition hover:text-foreground sm:inline">The Gear</a>
      <a href="#drop" class="hidden text-primary transition hover:brightness-110 sm:inline">The Drop &darr;</a>
      {/* Site-wide Fire / Ice switch */}
      <div class="inline-flex items-center gap-0.5 rounded-full border border-border bg-card/60 p-0.5 backdrop-blur-sm">
        <button
          type="button"
          data-cw="fire"
          aria-label="Fire theme"
          class="cw-btn rounded-full px-3 py-1.5 text-xs font-bold transition"
        >
          🔥
        </button>
        <button
          type="button"
          data-cw="ice"
          aria-label="Ice theme"
          class="cw-btn rounded-full px-3 py-1.5 text-xs font-bold transition"
        >
          🧊
        </button>
      </div>
    </nav>
  </header>

  <span id="top"></span>

  {/* ---- Hero ---- */}
  <Hero client:load />

  {/* ---- Brand story ---- */}
  <section
    id="story"
    class="relative overflow-hidden bg-gradient-to-br from-primary/10 via-transparent to-transparent px-6 py-28 sm:px-10"
  >
    <div class="mx-auto max-w-4xl text-center">
      <p
        data-reveal
        class="mb-5 text-xs font-semibold tracking-[0.4em] text-primary uppercase"
      >
        What we stand for
      </p>
      <h2
        data-reveal
        class="text-4xl font-extrabold tracking-tight sm:text-6xl"
      >
        GREATNESS ISN&rsquo;T GIVEN.<br />
        <span class="text-fire fire-text-glow">IT&rsquo;S TAKEN.</span>
      </h2>
      <p
        data-reveal
        class="mx-auto mt-8 max-w-2xl text-lg text-muted-foreground"
      >
        B-BUCKETS is for the ones who chase it — on the court, in the streets,
        every single day. No shortcuts, no excuses. You put in the work, you get
        the buckets. Be the G.O.A.T.
      </p>
    </div>
  </section>

  {/* ---- Meet the G.O.A.T. ---- */}
  <section
    id="goat"
    class="relative overflow-hidden border-y border-border bg-gradient-to-bl from-primary/12 via-transparent to-primary/5 px-6 py-28 sm:px-10"
  >
    <div
      class="mx-auto grid max-w-6xl items-center gap-12 md:grid-cols-2"
    >
      <div data-reveal class="relative flex justify-center">
        <img
          src="/img/brand/goat-color.webp"
          alt="The B-BUCKETS mascot — a goat in B-BUCKETS gear holding a basketball"
          data-fire="/img/brand/goat-color.webp"
          data-ice="/img/brand/goat-color-ice.webp"
          onerror="this.src='/img/brand/goat-color.webp'"
          class="theme-img animate-float relative w-[280px] drop-shadow-2xl sm:w-[360px]"
          width="360"
          height="540"
          loading="lazy"
        />
      </div>
      <div>
        <p
          data-reveal
          class="mb-4 text-xs font-semibold tracking-[0.4em] text-primary uppercase"
        >
          Meet the mascot
        </p>
        <h2
          data-reveal
          class="text-4xl font-extrabold tracking-tight sm:text-6xl"
        >
          THE <span class="text-fire fire-text-glow">G.O.A.T.</span>
        </h2>
        <p data-reveal class="mt-6 text-lg text-muted-foreground">
          Greatest Of All Time. Our goat doesn&rsquo;t chase the hype — it
          <span class="font-semibold text-foreground"> is </span>
          the hype. Cold, confident, and always getting buckets. It reps the
          flames head to toe, just like you will.
        </p>
        <p
          data-reveal
          class="mt-8 text-sm font-bold tracking-[0.25em] text-primary uppercase"
        >
          Get buckets.
        </p>
      </div>
    </div>
  </section>

  {/* ---- The Gear ---- */}
  <section id="gear" class="relative overflow-hidden px-6 py-28 sm:px-10">
    {/* Cool generated fire background behind all products (#3). */}
    <img
      src="/img/hero/products-bg.webp"
      alt=""
      aria-hidden="true"
      class="gear-bg absolute inset-0 h-full w-full object-cover opacity-45 transition-[filter] duration-500"
      loading="lazy"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-background via-background/60 to-background"
    >
    </div>
    <div class="relative mx-auto max-w-6xl">
      <div class="mb-10 text-center">
        <p
          data-reveal
          class="mb-4 text-xs font-semibold tracking-[0.4em] text-primary uppercase"
        >
          First drop
        </p>
        <h2
          data-reveal
          class="text-4xl font-extrabold tracking-tight sm:text-6xl"
        >
          THE <span id="gear-accent" class="text-fire fire-text-glow">GEAR</span>
        </h2>

        {/* Fire / Ice colorway toggle */}
        <div
          data-reveal
          class="mx-auto mt-8 inline-flex items-center gap-1 rounded-full border border-border bg-card/60 p-1 backdrop-blur-sm"
        >
          <button
            type="button"
            data-cw="fire"
            class="cw-btn rounded-full px-5 py-2 text-sm font-bold tracking-wide transition"
          >
            🔥 Fire
          </button>
          <button
            type="button"
            data-cw="ice"
            class="cw-btn rounded-full px-5 py-2 text-sm font-bold tracking-wide transition"
          >
            🧊 Ice
          </button>
        </div>

        {/* The collection name switches with the colorway. */}
        <p
          data-reveal
          class="mt-6 text-xs font-semibold tracking-[0.4em] uppercase"
        >
          <span class="text-muted-foreground">The drop:</span>
          <span id="drop-name" class="text-fire fire-text-glow"></span>
        </p>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          products.map((p) => {
            const iceFront = p.img.replace(".webp", "-ice.webp");
            const fireViews = viewsOf(p.img);
            const iceViews = viewsOf(iceFront);
            const isShoe = p.img.includes("shoes");
            return (
              <button
                type="button"
                data-reveal
                class="product-card group relative block overflow-hidden rounded-3xl border border-border bg-card/70 text-left backdrop-blur-sm transition duration-300 hover:-translate-y-2 hover:border-primary/60 hover:shadow-[0_20px_60px_-20px_var(--brand-red)]"
                data-name={p.name}
                data-views-fire={JSON.stringify(fireViews)}
                data-views-ice={JSON.stringify(iceViews)}
                data-saying-fire={p.sayingFire}
                data-saying-ice={p.sayingIce}
              >
                <div
                  class={`aspect-square overflow-hidden p-6 ${isShoe ? "shoe-bg" : "bg-white"}`}
                >
                  <img
                    src={p.img}
                    alt={p.name}
                    data-fire={p.img}
                    data-ice={iceFront}
                    class="product-img h-full w-full object-contain drop-shadow-[0_10px_22px_rgba(0,0,0,0.25)] transition duration-500 group-hover:scale-110"
                    width="800"
                    height="800"
                    loading="lazy"
                  />
                </div>
                <div class="flex items-center justify-between p-5">
                  <div>
                    <h3 class="text-lg font-bold">{p.name}</h3>
                    <p class="text-xs tracking-[0.2em] text-muted-foreground uppercase">
                      {p.tag}
                    </p>
                  </div>
                  <span class="rounded-full border border-primary/40 px-3 py-1 text-[10px] font-semibold tracking-[0.2em] text-primary uppercase">
                    3 views
                  </span>
                </div>
              </button>
            );
          })
        }
      </div>
    </div>
  </section>

  {/* ---- The G.O.A.T. in action (animated) ---- */}
  <section class="relative overflow-hidden">
    <img
      src="/img/hero/goat-action-still.webp"
      alt="The B-BUCKETS goat in a basketball shooting motion"
      class="goat-still h-[60svh] w-full object-cover sm:h-[80svh]"
      loading="lazy"
    />
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-t from-background via-transparent to-background/60"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-8 text-center"
    >
      <p data-reveal class="text-4xl font-extrabold tracking-tight sm:text-6xl">
        NOTHING BUT <span class="text-fire fire-text-glow">BUCKETS.</span>
      </p>
    </div>
  </section>

  {/* ---- The Drop / Countdown (the main moment) ---- */}
  <section
    id="drop"
    class="relative overflow-hidden border-t border-border px-6 py-32 sm:px-10"
  >
    <div class="bg-ember absolute inset-x-0 bottom-0 h-2/3"></div>
    <div class="relative mx-auto max-w-3xl text-center">
      <p
        data-reveal
        class="mb-4 text-xs font-semibold tracking-[0.4em] text-primary uppercase"
      >
        Mark your calendar
      </p>
      <h2
        data-reveal
        class="text-5xl font-extrabold tracking-tight sm:text-7xl"
      >
        THE <span class="text-fire fire-text-glow">DROP</span>
      </h2>
      <p data-reveal class="mx-auto mt-5 mb-12 max-w-md text-muted-foreground">
        Drop One lands soon. When the clock hits zero, it&rsquo;s go time.
      </p>

      <Countdown client:visible target={DROP_DATE} />

      <p
        data-reveal
        class="mt-12 text-sm font-bold tracking-[0.3em] text-foreground uppercase"
      >
        Be ready. Get buckets.
      </p>
    </div>
  </section>

  {/* ---- Footer ---- */}
  <footer
    class="flex flex-col items-center gap-4 border-t border-border px-6 py-12 text-center sm:flex-row sm:justify-between sm:text-left"
  >
    <img
      src="/img/brand/logo-transparent.png"
      alt="B-BUCKETS logo"
      class="h-7 w-auto invert"
      width="42"
      height="28"
    />
    <p class="text-xs tracking-[0.25em] text-muted-foreground uppercase">
      Get buckets.
    </p>
    <p class="text-xs text-muted-foreground">
      &copy; {year} B-BUCKETS. All rights reserved.
    </p>
  </footer>

  {/* ---- Product 3-view gallery popup ---- */}
  <div
    id="gallery"
    class="fixed inset-0 z-50 hidden items-center justify-center p-4"
  >
    <div
      class="absolute inset-0 bg-black/85 backdrop-blur-sm"
      data-gclose
    >
    </div>
    <div class="relative z-10 w-full max-w-xl">
      <button
        type="button"
        data-gclose
        aria-label="Close"
        class="absolute -top-12 right-0 flex h-10 w-10 items-center justify-center rounded-full bg-background/70 text-xl transition hover:bg-primary hover:text-primary-foreground"
      >
        &times;
      </button>
      <div
        id="g-stage"
        class="relative flex aspect-square items-center justify-center overflow-hidden rounded-3xl border border-border"
      >
        <img
          id="g-img"
          alt=""
          class="max-h-full max-w-full object-contain p-6 drop-shadow-[0_10px_22px_rgba(0,0,0,0.3)]"
        />
        <button
          type="button"
          id="g-prev"
          aria-label="Previous view"
          class="absolute left-2 flex h-11 w-11 items-center justify-center rounded-full bg-background/70 text-2xl transition hover:bg-primary hover:text-primary-foreground"
        >
          &lsaquo;
        </button>
        <button
          type="button"
          id="g-next"
          aria-label="Next view"
          class="absolute right-2 flex h-11 w-11 items-center justify-center rounded-full bg-background/70 text-2xl transition hover:bg-primary hover:text-primary-foreground"
        >
          &rsaquo;
        </button>
      </div>
      <div class="mt-4 text-center">
        <h3 id="g-name" class="text-xl font-bold"></h3>
        <div id="g-dots" class="mt-3 flex justify-center gap-2"></div>
        <div
          class="mx-auto mt-4 max-w-xs rounded-2xl border border-border bg-card/60 px-4 py-3 backdrop-blur-sm"
        >
          <p class="text-[10px] font-semibold tracking-[0.3em] text-muted-foreground uppercase">
            🔒 Secret inside
          </p>
          <p id="g-secret" class="mt-1 font-bold"></p>
        </div>
      </div>
    </div>
  </div>

  {/* Fire / Ice colorway toggle + 3-view gallery */}
  <script>
    const imgs = document.querySelectorAll<HTMLImageElement>(
      ".product-img, .theme-img",
    );
    const fireBtns = document.querySelectorAll<HTMLElement>('[data-cw="fire"]');
    const iceBtns = document.querySelectorAll<HTMLElement>('[data-cw="ice"]');
    const dropName = document.getElementById("drop-name");
    const VIEW_LABELS = ["Front", "Back", "Side"];
    const DROP_NAMES = { fire: "HEAT CHECK", ice: "ICE IN MY VEINS" };

    let colorway: "fire" | "ice" = "fire";

    function setColorway(mode: "fire" | "ice") {
      colorway = mode;
      const ice = mode === "ice";
      // The whole site flips red <-> blue via this one class on <html>.
      document.documentElement.classList.toggle("theme-ice", ice);
      imgs.forEach((img) => {
        const next = ice ? img.dataset.ice : img.dataset.fire;
        if (next) img.src = next;
      });
      if (dropName) dropName.textContent = DROP_NAMES[mode];
      fireBtns.forEach((b) => b.classList.toggle("on-fire", !ice));
      iceBtns.forEach((b) => b.classList.toggle("on-ice", ice));
    }
    fireBtns.forEach((b) => b.addEventListener("click", () => setColorway("fire")));
    iceBtns.forEach((b) => b.addEventListener("click", () => setColorway("ice")));
    setColorway("fire");

    // ---- Gallery ----
    const gallery = document.getElementById("gallery")!;
    const gStage = document.getElementById("g-stage")!;
    const gImg = document.getElementById("g-img") as HTMLImageElement;
    const gName = document.getElementById("g-name")!;
    const gDots = document.getElementById("g-dots")!;
    const gSecret = document.getElementById("g-secret")!;
    let views: string[] = [];
    let idx = 0;

    function bgFor(isShoe: boolean) {
      if (!isShoe) return "#ffffff";
      return colorway === "ice"
        ? "radial-gradient(circle at 50% 62%, #14357a 0%, #060a1c 80%)"
        : "radial-gradient(circle at 50% 62%, #7a1414 0%, #180909 78%)";
    }

    function show(i: number) {
      idx = (i + views.length) % views.length;
      gImg.src = views[idx];
      Array.from(gDots.children).forEach((d, k) =>
        d.classList.toggle("bg-primary", k === idx),
      );
    }

    function openGallery(card: HTMLElement) {
      const raw =
        colorway === "ice"
          ? card.dataset.viewsIce
          : card.dataset.viewsFire;
      views = JSON.parse(raw || "[]");
      if (views.length === 0) {
        // Fallback to whatever the card is currently showing.
        const cur = card.querySelector("img");
        if (cur) views = [cur.src];
      }
      const isShoe = (views[0] || "").includes("shoes");
      gStage.style.background = bgFor(isShoe);
      gName.textContent = card.dataset.name || "";
      const saying =
        colorway === "ice"
          ? card.dataset.sayingIce
          : card.dataset.sayingFire;
      gSecret.textContent = saying || "";
      gSecret.className =
        "mt-1 font-bold " + (colorway === "ice" ? "text-ice" : "text-fire");
      gDots.innerHTML = "";
      views.forEach((_, k) => {
        const dot = document.createElement("button");
        dot.className =
          "h-2.5 w-2.5 rounded-full border border-border transition";
        dot.setAttribute("aria-label", VIEW_LABELS[k] || `View ${k + 1}`);
        dot.addEventListener("click", () => show(k));
        gDots.appendChild(dot);
      });
      show(0);
      gallery.classList.remove("hidden");
      gallery.classList.add("flex");
      document.body.style.overflow = "hidden";
    }

    function closeGallery() {
      gallery.classList.add("hidden");
      gallery.classList.remove("flex");
      document.body.style.overflow = "";
    }

    document
      .querySelectorAll<HTMLElement>(".product-card")
      .forEach((c) => c.addEventListener("click", () => openGallery(c)));
    document
      .getElementById("g-prev")
      ?.addEventListener("click", () => show(idx - 1));
    document
      .getElementById("g-next")
      ?.addEventListener("click", () => show(idx + 1));
    gallery
      .querySelectorAll("[data-gclose]")
      .forEach((b) => b.addEventListener("click", closeGallery));
    document.addEventListener("keydown", (e) => {
      if (gallery.classList.contains("hidden")) return;
      if (e.key === "Escape") closeGallery();
      if (e.key === "ArrowLeft") show(idx - 1);
      if (e.key === "ArrowRight") show(idx + 1);
    });
  </script>

  {/* Scroll-reveal: reveal [data-reveal] elements as they enter the viewport. */}
  <script>
    const els = document.querySelectorAll("[data-reveal]");
    const obs = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            obs.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12 },
    );
    els.forEach((el) => obs.observe(el));
  </script>
</Layout>
