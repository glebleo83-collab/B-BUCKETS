---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero.tsx";
import Countdown from "@/components/Countdown.tsx";

const year = new Date().getFullYear();

// 🔧 EDIT ME: the real drop date/time (Pacific). Change this one line when you
// know your launch day — the countdown updates automatically.
const DROP_DATE = "2026-08-08T10:00:00-07:00";

// 🔧 EDIT ME: product names/labels are placeholders — rename freely.
const products = [
  { name: "Flame Sneakers", tag: "Footwear", img: "/img/products/shoes.webp" },
  { name: "Flame Hoodie", tag: "Apparel", img: "/img/products/hoodie.webp" },
  { name: "BB Ringer Tee", tag: "Apparel", img: "/img/products/tee.webp" },
  { name: "Flame Shorts", tag: "Apparel", img: "/img/products/shorts.webp" },
  {
    name: "Flame Sweatpants",
    tag: "Apparel",
    img: "/img/products/sweatpants.webp",
  },
  { name: "BB Bucket Hat", tag: "Headwear", img: "/img/products/hat.webp" },
  { name: "Flame Socks", tag: "Apparel", img: "/img/products/socks.webp" },
  {
    name: "BB Bracelets",
    tag: "Accessories",
    img: "/img/products/bracelets.webp",
  },
  { name: "Flame Boxers", tag: "Apparel", img: "/img/products/underwear.webp" },
];
---

<Layout title="B-BUCKETS — Buckets Incoming">
  {/* ---- Header ---- */}
  <header
    class="fixed inset-x-0 top-0 z-40 flex items-center justify-between bg-gradient-to-b from-background/90 to-transparent px-6 py-4 backdrop-blur-sm sm:px-10"
  >
    <a href="#top" class="flex items-center gap-3">
      <img
        src="/img/brand/logo-transparent.png"
        alt="B-BUCKETS logo"
        class="h-8 w-auto invert"
        width="48"
        height="32"
      />
    </a>
    <nav class="flex items-center gap-6 text-xs font-semibold tracking-[0.2em] uppercase">
      <a href="#goat" class="hidden text-muted-foreground transition hover:text-foreground sm:inline">The G.O.A.T.</a>
      <a href="#gear" class="hidden text-muted-foreground transition hover:text-foreground sm:inline">The Gear</a>
      <a href="#drop" class="text-primary transition hover:brightness-110">The Drop &darr;</a>
    </nav>
  </header>

  <span id="top"></span>

  {/* ---- Hero ---- */}
  <Hero client:load />

  {/* ---- Brand story ---- */}
  <section
    id="story"
    class="relative overflow-hidden bg-gradient-to-br from-primary/10 via-transparent to-transparent px-6 py-28 sm:px-10"
  >
    <div class="mx-auto max-w-4xl text-center">
      <p
        data-reveal
        class="mb-5 text-xs font-semibold tracking-[0.4em] text-primary uppercase"
      >
        What we stand for
      </p>
      <h2
        data-reveal
        class="text-4xl font-extrabold tracking-tight sm:text-6xl"
      >
        GREATNESS ISN&rsquo;T GIVEN.<br />
        <span class="text-fire fire-text-glow">IT&rsquo;S TAKEN.</span>
      </h2>
      <p
        data-reveal
        class="mx-auto mt-8 max-w-2xl text-lg text-muted-foreground"
      >
        B-BUCKETS is for the ones who chase it — on the court, in the streets,
        every single day. No shortcuts, no excuses. You put in the work, you get
        the buckets. Be the G.O.A.T.
      </p>
    </div>
  </section>

  {/* ---- Meet the G.O.A.T. ---- */}
  <section
    id="goat"
    class="relative overflow-hidden border-y border-border bg-gradient-to-bl from-primary/12 via-transparent to-primary/5 px-6 py-28 sm:px-10"
  >
    <div
      class="mx-auto grid max-w-6xl items-center gap-12 md:grid-cols-2"
    >
      <div data-reveal class="relative flex justify-center">
        <img
          src="/img/brand/goat-color.webp"
          alt="The B-BUCKETS mascot — a goat in red and black flame B-BUCKETS gear holding a basketball"
          class="animate-float relative w-[280px] drop-shadow-2xl sm:w-[360px]"
          width="360"
          height="540"
          loading="lazy"
        />
      </div>
      <div>
        <p
          data-reveal
          class="mb-4 text-xs font-semibold tracking-[0.4em] text-primary uppercase"
        >
          Meet the mascot
        </p>
        <h2
          data-reveal
          class="text-4xl font-extrabold tracking-tight sm:text-6xl"
        >
          THE <span class="text-fire fire-text-glow">G.O.A.T.</span>
        </h2>
        <p data-reveal class="mt-6 text-lg text-muted-foreground">
          Greatest Of All Time. Our goat doesn&rsquo;t chase the hype — it
          <span class="font-semibold text-foreground"> is </span>
          the hype. Cold, confident, and always getting buckets. It reps the
          flames head to toe, just like you will.
        </p>
        <p
          data-reveal
          class="mt-8 text-sm font-bold tracking-[0.25em] text-primary uppercase"
        >
          Get buckets.
        </p>
      </div>
    </div>
  </section>

  {/* ---- The Gear ---- */}
  <section id="gear" class="relative overflow-hidden px-6 py-28 sm:px-10">
    {/* Cool generated fire background behind all products (#3). */}
    <img
      src="/img/hero/products-bg.webp"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover opacity-45"
      loading="lazy"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-background via-background/60 to-background"
    >
    </div>
    <div class="relative mx-auto max-w-6xl">
      <div class="mb-14 text-center">
        <p
          data-reveal
          class="mb-4 text-xs font-semibold tracking-[0.4em] text-primary uppercase"
        >
          First drop
        </p>
        <h2
          data-reveal
          class="text-4xl font-extrabold tracking-tight sm:text-6xl"
        >
          THE <span class="text-fire fire-text-glow">GEAR</span>
        </h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          products.map((p) => (
            <article
              data-reveal
              class="group relative overflow-hidden rounded-3xl border border-border bg-card/70 backdrop-blur-sm transition duration-300 hover:-translate-y-2 hover:border-primary/60 hover:shadow-[0_20px_60px_-20px_var(--brand-red)]"
            >
              <div class="aspect-square overflow-hidden p-6">
                <img
                  src={p.img}
                  alt={p.name}
                  class="h-full w-full object-contain drop-shadow-[0_14px_30px_rgba(0,0,0,0.55)] transition duration-500 group-hover:scale-110"
                  width="800"
                  height="800"
                  loading="lazy"
                />
              </div>
              <div class="flex items-center justify-between p-5">
                <div>
                  <h3 class="text-lg font-bold">{p.name}</h3>
                  <p class="text-xs tracking-[0.2em] text-muted-foreground uppercase">
                    {p.tag}
                  </p>
                </div>
                <span class="rounded-full border border-primary/40 px-3 py-1 text-[10px] font-semibold tracking-[0.2em] text-primary uppercase">
                  Soon
                </span>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* ---- The G.O.A.T. in action (animated) ---- */}
  <section class="relative overflow-hidden">
    <video
      class="h-[60svh] w-full object-cover sm:h-[80svh]"
      poster="/img/hero/goat-action.webp"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      aria-label="The B-BUCKETS goat shooting a basketball"
    >
      <source src="/img/hero/goat-action.mp4" type="video/mp4" />
    </video>
    <div
      class="pointer-events-none absolute inset-0 bg-gradient-to-t from-background via-transparent to-background/60"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 bottom-8 text-center"
    >
      <p data-reveal class="text-4xl font-extrabold tracking-tight sm:text-6xl">
        NOTHING BUT <span class="text-fire fire-text-glow">BUCKETS.</span>
      </p>
    </div>
  </section>

  {/* ---- The Drop / Countdown (the main moment) ---- */}
  <section
    id="drop"
    class="relative overflow-hidden border-t border-border px-6 py-32 sm:px-10"
  >
    <div class="bg-ember absolute inset-x-0 bottom-0 h-2/3"></div>
    <div class="relative mx-auto max-w-3xl text-center">
      <p
        data-reveal
        class="mb-4 text-xs font-semibold tracking-[0.4em] text-primary uppercase"
      >
        Mark your calendar
      </p>
      <h2
        data-reveal
        class="text-5xl font-extrabold tracking-tight sm:text-7xl"
      >
        THE <span class="text-fire fire-text-glow">DROP</span>
      </h2>
      <p data-reveal class="mx-auto mt-5 mb-12 max-w-md text-muted-foreground">
        Drop One lands soon. When the clock hits zero, it&rsquo;s go time.
      </p>

      <Countdown client:visible target={DROP_DATE} />

      <p
        data-reveal
        class="mt-12 text-sm font-bold tracking-[0.3em] text-foreground uppercase"
      >
        Be ready. Get buckets.
      </p>
    </div>
  </section>

  {/* ---- Footer ---- */}
  <footer
    class="flex flex-col items-center gap-4 border-t border-border px-6 py-12 text-center sm:flex-row sm:justify-between sm:text-left"
  >
    <img
      src="/img/brand/logo-transparent.png"
      alt="B-BUCKETS logo"
      class="h-7 w-auto invert"
      width="42"
      height="28"
    />
    <p class="text-xs tracking-[0.25em] text-muted-foreground uppercase">
      Get buckets.
    </p>
    <p class="text-xs text-muted-foreground">
      &copy; {year} B-BUCKETS. All rights reserved.
    </p>
  </footer>

  {/* Scroll-reveal: reveal [data-reveal] elements as they enter the viewport. */}
  <script>
    const els = document.querySelectorAll("[data-reveal]");
    const obs = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            obs.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12 },
    );
    els.forEach((el) => obs.observe(el));
  </script>
</Layout>
